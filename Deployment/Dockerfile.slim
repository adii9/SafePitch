# Dockerfile.slim — safedeck-minimax Lambda image
#
# Standalone image: no Lambda layers. Patched 13 Jun 2026 after layer-pivot
# was abandoned (50MB layer limit + 5-layer cap made it impractical).
# Install only what safepitch actually needs — no `crewai[google-genai,tools]`
# (which pulls the Gemini extras + dozens of unused tools packages).

FROM --platform=linux/amd64 public.ecr.aws/lambda/python:3.12

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=${LAMBDA_TASK_ROOT}/src

# Build tools for compiling any C-extensions
RUN dnf install -y gcc gcc-c++ make \
    && dnf clean all

# Install uv
RUN pip install uv

WORKDIR ${LAMBDA_TASK_ROOT}

# Copy project files for dependency install
COPY pyproject.toml uv.lock ./

# Install from pyproject — gets exactly what safepitch declares, nothing more.
# We install to LAMBDA_TASK_ROOT so the package is on sys.path under that root.
RUN uv pip install --system --no-cache .

# Copy application source
COPY src/ ./src/
COPY knowledge/ ./knowledge/
COPY Deployment/lambda_function.py ./

# Lambda runs as a non-root user; the runtime needs to read these.
# Without chmod the import fails with PermissionError at cold start.
# (The fat Dockerfile did this for lambda_function.py only; slim needs
# it for the whole task root because the safepitch package is here too.)
RUN chmod -R o+rX ${LAMBDA_TASK_ROOT}

# Smoke check: the imports that must resolve on Lambda cold start
RUN python -c "import safepitch.main; print('Slim imports OK')"

# Lambda runtime contract: the base image's ENTRYPOINT runs the Lambda RIE;
# CMD names the module.function handler.
CMD [ "lambda_function.lambda_handler" ]